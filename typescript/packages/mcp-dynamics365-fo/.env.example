# ─── Dynamics 365 F&O Connection ───────────────────────────────────────────────
# Azure AD tenant ID (find in Azure Portal > Azure Active Directory > Overview)
D365_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Azure AD App Registration client ID
# Create at: Azure Portal > App registrations > New registration
D365_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Azure AD App Registration client secret
# Create at: App registration > Certificates & secrets > New client secret
D365_CLIENT_SECRET=your-client-secret-here

# Dynamics 365 F&O base URL (without trailing slash)
# Example: https://myorg.operations.dynamics.com
D365_BASE_URL=https://your-org.operations.dynamics.com

# ─── Optional Settings ──────────────────────────────────────────────────────────
# Default legal entity / company to query (e.g. USMF, DAT, DEMF)
# Leave blank to query across all companies
D365_DEFAULT_COMPANY=USMF

# Authentication mode: clientSecret | managedIdentity | deviceCode | certificate
D365_AUTH_MODE=clientSecret

# Certificate auth (only required when D365_AUTH_MODE=certificate)
# D365_CERT_PATH=/path/to/certificate.pem
# D365_CERT_PASSWORD=optional-cert-password

# HTTP request timeout in milliseconds (default: 30000)
D365_TIMEOUT_MS=30000

# Max retries on transient errors (default: 3)
D365_MAX_RETRIES=3
