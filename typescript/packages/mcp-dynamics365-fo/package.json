  "author": "Microsoft",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-dynamics365-fo": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "clean": "rimraf dist",
    "start": "node dist/index.js",
